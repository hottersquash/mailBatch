# SMTP server
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_TLS=true

# Account
SMTP_USER=your_account@example.com
SMTP_PASSWORD=your_password_or_app_token
MAIL_FROM=your_account@example.com

# Seconds between each email (0 = no delay)
SEND_INTERVAL=1.0

# Default subject (UI can override)
MAIL_SUBJECT=新员工入职指引
